{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ZenRows/zenrows-mcp",
  "description": "ZenRows MCP server — Universal Scraper API for AI coding assistants",
  "author": {
    "name": "ZenRows",
    "url": "https://github.com/ZenRows"
  },
  "repository": {
    "url": "https://github.com/ZenRows/zenrows-mcp",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@zenrows/mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your ZenRows API key from https://app.zenrows.com/account/settings",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "ZENROWS_API_KEY"
        }
      ]
    }
  ]
}
